{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isOnline": { "type": "boolean" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName"]
    },
    "ChatRoom": {
      "title": "ChatRoom",
      "description": "A 1-to-1 chat session between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "createdAt", "active"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat room",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["text", "image", "system"] },
        "moderated": { "type": "boolean" }
      },
      "required": ["senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/rooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Active and past chat sessions"
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a specific room"
    }
  }
}
